# Copy to .env and adjust as needed. Do NOT commit the real .env.

# PostgreSQL
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing
POSTGRES_DB=ticketing

# API
JWT_SECRET=change-me-in-production
APP_BASE_URL=http://localhost:8080

# SMTP — dev uses the bundled mailhog container.
# For production/QA set SMTP_HOST=relay1.dataart.com and the appropriate port.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@ticketing.local
